# Copie este arquivo para .env e preencha com seus valores.
# .env NÃO deve ser versionado (já está no .gitignore).

# Chave privada do deployer (sem 0x na frente). Use uma carteira dedicada à testnet.
PRIVATE_KEY=

# URLs RPC (opcionais — se vazias, o hardhat.config.ts usa endpoints públicos)
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# Habilita fork de mainnet ao rodar `pnpm fork` (não usado normalmente)
MAINNET_FORKING_ENABLED=false
